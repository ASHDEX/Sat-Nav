{
  "version": 8,
  "name": "{{STYLE_NAME}}",
  "metadata": {
    "generator": "Satnav MBTiles local server - Vector"
  },
  "sources": {
    "offline-vector": {
      "type": "vector",
      "tiles": ["{{TILES_URL}}"],
      "scheme": "{{SCHEME}}",
      "minzoom": {{MIN_ZOOM}},
      "maxzoom": {{MAX_ZOOM}},
      "bounds": {{BOUNDS}},
      "attribution": "{{ATTRIBUTION}}"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#eef3f7"
      }
    },
    {
      "id": "landcover",
      "type": "fill",
      "source": "offline-vector",
      "source-layer": "landcover",
      "filter": ["==", "$type", "Polygon"],
      "paint": {
        "fill-color": "#dce8cf",
        "fill-opacity": 0.75
      }
    },
    {
      "id": "landuse",
      "type": "fill",
      "source": "offline-vector",
      "source-layer": "landuse",
      "filter": ["==", "$type", "Polygon"],
      "paint": {
        "fill-color": "#e3ecd8",
        "fill-opacity": 0.65
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "offline-vector",
      "source-layer": "water",
      "filter": ["==", "$type", "Polygon"],
      "paint": {
        "fill-color": "#a0c8f0"
      }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "offline-vector",
      "source-layer": "waterway",
      "filter": ["==", "$type", "LineString"],
      "paint": {
        "line-color": "#84bde8",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          5, 0.4,
          10, 1.2,
          14, 2.5
        ]
      }
    },
    {
      "id": "roads",
      "type": "line",
      "source": "offline-vector",
      "source-layer": "transportation",
      "filter": ["==", "$type", "LineString"],
      "paint": {
        "line-color": "#5d5d5d",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          5, 0.5,
          10, 1.6,
          14, 4.0
        ]
      }
    },
    {
      "id": "buildings",
      "type": "fill",
      "source": "offline-vector",
      "source-layer": "building",
      "filter": ["==", "$type", "Polygon"],
      "paint": {
        "fill-color": "#cccccc",
        "fill-opacity": 0.7
      }
    }
  ]
}
