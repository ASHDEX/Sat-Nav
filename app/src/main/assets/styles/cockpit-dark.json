{
  "version": 8,
  "name": "{{STYLE_NAME}}",
  "metadata": {
    "generator": "Satnav Cockpit Dark - Night Driving"
  },
  "sources": {
    "offline-vector": {
      "type": "vector",
      "tiles": ["{{TILES_URL}}"],
      "scheme": "{{SCHEME}}",
      "minzoom": {{MIN_ZOOM}},
      "maxzoom": {{MAX_ZOOM}},
      "bounds": {{BOUNDS}},
      "attribution": "{{ATTRIBUTION}}"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#0B1016"
      }
    },
    {
      "id": "landcover",
      "type": "fill",
      "source": "offline-vector",
      "source-layer": "landcover",
      "filter": ["==", "$type", "Polygon"],
      "paint": {
        "fill-color": "#1A2A2A",
        "fill-opacity": 0.6
      }
    },
    {
      "id": "landuse",
      "type": "fill",
      "source": "offline-vector",
      "source-layer": "landuse",
      "filter": ["==", "$type", "Polygon"],
      "paint": {
        "fill-color": "#1E3A2A",
        "fill-opacity": 0.5
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "offline-vector",
      "source-layer": "water",
      "filter": ["==", "$type", "Polygon"],
      "paint": {
        "fill-color": "#1E3A5A"
      }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "offline-vector",
      "source-layer": "waterway",
      "filter": ["==", "$type", "LineString"],
      "paint": {
        "line-color": "#2A4A7A",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          5, 0.4,
          10, 1.2,
          14, 2.5
        ]
      }
    },
    {
      "id": "roads-casing",
      "type": "line",
      "source": "offline-vector",
      "source-layer": "transportation",
      "filter": ["==", "$type", "LineString"],
      "paint": {
        "line-color": [
          "match",
          ["get", "class"],
          "motorway", "#FFA726",
          "trunk", "#FFB74D",
          "primary", "#FFCC80",
          "secondary", "#E0E0E0",
          "tertiary", "#BDBDBD",
          "residential", "#757575",
          "service", "#616161",
          "#424242"
        ],
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          5, 1.0,
          10, 3.2,
          14, 8.0
        ],
        "line-opacity": 0.9
      }
    },
    {
      "id": "roads",
      "type": "line",
      "source": "offline-vector",
      "source-layer": "transportation",
      "filter": ["==", "$type", "LineString"],
      "paint": {
        "line-color": [
          "match",
          ["get", "class"],
          "motorway", "#FF9800",
          "trunk", "#FFA726",
          "primary", "#FFB74D",
          "secondary", "#EEEEEE",
          "tertiary", "#BDBDBD",
          "residential", "#616161",
          "service", "#424242",
          "#212121"
        ],
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          5, 0.5,
          10, 1.6,
          14, 4.0
        ],
        "line-opacity": 0.8
      }
    },
    {
      "id": "buildings",
      "type": "fill",
      "source": "offline-vector",
      "source-layer": "building",
      "filter": ["==", "$type", "Polygon"],
      "paint": {
        "fill-color": "#37474F",
        "fill-opacity": 0.5
      }
    },
    {
      "id": "labels",
      "type": "symbol",
      "source": "offline-vector",
      "source-layer": "place",
      "filter": ["==", "$type", "Point"],
      "layout": {
        "text-field": ["get", "name"],
        "text-size": [
          "interpolate",
          ["linear"],
          ["zoom"],
          5, 10,
          10, 12,
          14, 14
        ],
        "text-font": ["Noto Sans Regular"]
      },
      "paint": {
        "text-color": "#FFFFFF",
        "text-halo-color": "#000000",
        "text-halo-width": 1.5
      }
    }
  ]
}